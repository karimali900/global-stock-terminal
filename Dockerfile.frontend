FROM docker.io/library/python:3.10-slim

# Maintain the baseline font structure for chart rendering
RUN apt-get update && apt-get install -y --no-install-recommends \
    libfontconfig1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy your corrected dashboard filename
COPY stock_dashboardx.py .

EXPOSE 8501

CMD ["streamlit", "run", "stock_dashboardx.py", "--server.port=8501", "--server.address=0.0.0.0"]
